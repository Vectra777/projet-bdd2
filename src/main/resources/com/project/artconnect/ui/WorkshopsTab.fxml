<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.WorkshopController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <TableView fx:id="workshopTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="200" />
            <TableColumn fx:id="instructorColumn" text="Instructor" prefWidth="150" />
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="180" />
            <TableColumn fx:id="priceColumn" text="Price" prefWidth="100" />
            <TableColumn fx:id="levelColumn" text="Level" prefWidth="120" />
        </columns>
    </TableView>
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button text="Add Workshop" onAction="#handleAdd" />
        <Button text="Edit Workshop" onAction="#handleEdit" />
        <Button text="Delete Workshop" onAction="#handleDelete" />
    </HBox>
</VBox>
